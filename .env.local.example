# =========================================================================
#  Controle de Presença Hard Cranes — variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha com os SEUS valores.
#  NUNCA envie o .env.local para o Git nem mande as chaves por WhatsApp.
# =========================================================================

# --- Supabase ---
# Pegue em: Supabase -> seu projeto -> Settings -> API
# "Project URL"
NEXT_PUBLIC_SUPABASE_URL=

# "Project API keys" -> "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "Project API keys" -> "service_role" (SECRETA — só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# --- Quiosque (celular da parede) ---
# Senha do dispositivo que você define. Só quem digitar esse código
# no celular da parede consegue registrar presença. Troque quando quiser.
KIOSK_DEVICE_TOKEN=troque-esta-senha

# --- Reconhecimento facial ---
# Distância máxima aceita entre o rosto da batida e o cadastro.
# Menor = mais rígido. 0.5 é um bom ponto de partida para chão de fábrica.
NEXT_PUBLIC_FACE_MATCH_THRESHOLD=0.5
